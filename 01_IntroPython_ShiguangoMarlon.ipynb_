{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyPWRZlt2gKoRDMbtiB5cGcH"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ZwvevwUYWwf9","executionInfo":{"status":"ok","timestamp":1775844811683,"user_tz":300,"elapsed":54,"user":{"displayName":"Marlon Shiguango Zapata","userId":"04014797808892235737"}},"outputId":"58f943e8-e40e-46db-98bb-dbb90f46ffdc"},"outputs":[{"output_type":"stream","name":"stdout","text":["Usuario: Juan Perez\n","Edad: 20\n"]}],"source":["# Declaracion de variables (Atributos de una entidad)\n","nombre_usuario = \"Juan Perez\"  # String (Texto)\n","edad = 20\n","promedio = 8.5\n","es_estudiante = True\n","print(f\"Usuario: {nombre_usuario}\")\n","print(f\"Edad: {edad}\")\n","\n","\n","if edad >= 18:\n","  mensaje = \"Usuario mayor de edad: Acceso total al SI.\"\n","\n","else:\n","  mensaje = \"Usuario menor de edad: Acceso restringido.\"\n","  print(mensaje)\n","\n","  #Lista de componentes de un SI\n","  Componentes_si = [\"Hardware\" , \"Software\", \"Datos\", \"Redes\", \"Personas\", \"Procesos\"]\n","  print(\"Componentes a auditar: \")\n","  for item in Componentes_si:\n","    print(f\"- {item}\")\n","\n","    import pandas as pd\n","\n","    #Creacion de un DataFrame manual (Simulando una base de datos)\n","    datos_empresa = {\n","        'Producto': ['Laptop', 'Mouse', 'Monitor', 'Teclado'],\n","        'Precio' : [1200, 25, 200, 45],\n","        'Stock' : [15, 100, 20, 50]\n","\n","    }\n","\n","    df = pd.DataFrame (datos_empresa)\n","\n","    #Visualizacion de los primeros registros\n","    print(\"Vista previa del sistema de inventario: \")\n","    print(df.head())\n","\n","    #Operacion basica: Calcular el valor total del inventario\n","    total_inventario = (df['Precio'] * df['Stock']).sum()\n","    print(f\"\\nValor total en archivos de hardware: ${total_inventario}\")\n","\n","    from google.colab import files\n","    uploaded = files.upload()\n","\n","    import pandas as pd\n","    df = pd.read_csv(\"tinatic.cvs\")\n","    df. head()\n","    df.describe()\n","\n","\n","\n","\n"]},{"cell_type":"code","source":["from google.colab import drive\n","drive.mount('/content/drive')\n","\n","import pandas as pd\n","df = pd.read_csv('/content/drive/MyDrive/titanic.csv')\n","df.head()\n","df.describe()\n","\n","porcentaje_supervivencia = (df['Survived'] == 1).mean() * 100\n","print(\"Porcentaje de supervivencia: \", porcentaje_supervivencia)\n","porcentaje_clase = df['Pclass'].value_counts(normalize=True) * 100\n","porcentaje_clase.index = [\"Alta\", \"Media\", \"Baja\"]\n","print(\"\\nPorcentaje de clase: \\n\", porcentaje_clase)\n","df[\"Sex\"].value_counts()\n","df.groupby(\"Sex\")[\"Survived\"].mean() * 100\n","\n","print(\"\\nCantidad por genero: \\n\", df[\"Sex\"].value_counts())\n","print(\"\\nSupervivencia por genero: \\n\",df.groupby(\"Sex\")[\"Survived\"].mean() * 100)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"NkM68DZwqrB8","executionInfo":{"status":"ok","timestamp":1776134924055,"user_tz":300,"elapsed":29238,"user":{"displayName":"Marlon Shiguango Zapata","userId":"04014797808892235737"}},"outputId":"cf6337c7-902f-48cc-a097-839517a1f54e"},"execution_count":1,"outputs":[{"output_type":"stream","name":"stdout","text":["Mounted at /content/drive\n","Porcentaje de supervivencia:  38.38383838383838\n","\n","Porcentaje de clase: \n"," Alta     55.106622\n","Media    24.242424\n","Baja     20.650954\n","Name: proportion, dtype: float64\n","\n","Cantidad por genero: \n"," Sex\n","male      577\n","female    314\n","Name: count, dtype: int64\n","\n","Supervivencia por genero: \n"," Sex\n","female    74.203822\n","male      18.890815\n","Name: Survived, dtype: float64\n"]}]},{"cell_type":"markdown","source":[],"metadata":{"id":"V-okm6WDhZIs"}}]}